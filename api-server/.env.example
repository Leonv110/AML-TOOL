# Express API Server — PostgreSQL connection (Supabase)
# Password special characters are URL-encoded: @ = %40, # = %23
DATABASE_URL="postgresql://<username>:<url_encoded_password>@<host>:<port>/<database>?pgbouncer=true"

# JWT secret for authentication (generate a random string)
JWT_SECRET="your_jwt_secret_here"

# Port (default is 3001)
PORT=3001

# AML Watcher Credentials (Replace with your actual account info)
AMLWATCHER_EMAIL="your_email@example.com"
AMLWATCHER_PASSWORD="your_amlwatcher_password_here"
AMLWATCHER_API_KEY="your_amlwatcher_api_key_here"
