# GAFA — AML Training Platform: Environment Variables
# Copy this file to .env and fill in your values

# Express API Server URL
VITE_API_URL=http://localhost:3001

# Gemini AI — leave empty until API key is ready
VITE_GEMINI_KEY=your_gemini_api_key_when_ready

# Screening API
VITE_SCREENING_API_URL=your_screening_api_url_when_ready

# AML Processing Backend (FastAPI)
VITE_AML_BACKEND_URL=http://localhost:8000

# Audit Log HMAC Secret (any random string for signing audit entries)
VITE_AUDIT_HMAC_SECRET=change-this-to-a-random-secret
