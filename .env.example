# GAFA — AML Training Platform: Environment Variables
# Copy this file to .env and fill in your values

# Supabase — required for database and auth
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini AI — leave empty until API key is ready
VITE_GEMINI_KEY=your_gemini_api_key_when_ready

# Screening API — leave empty until Kanwaljeet's API is ready
VITE_SCREENING_API_URL=your_screening_api_url_when_ready
